# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Pooled connection string — used at runtime by Prisma (and PgBouncer on Supabase).
# In Supabase: Settings → Database → Connection string → Transaction mode (port 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?sslmode=require&pgbouncer=true"

# Direct connection string — used by Prisma Migrate (bypasses PgBouncer).
# In Supabase: Settings → Database → Connection string → Session mode (port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── SMTP (email notifications) ────────────────────────────────────────────────
# All four vars must be set to enable email notifications; if any is missing the
# app will skip sending and log a warning instead of erroring.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Address that receives new inquiry notifications
INQUIRY_TO_EMAIL=
# Address shown in the From header (defaults to SMTP_USER if omitted)
INQUIRY_FROM_EMAIL=

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL="https://your-domain.com"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to sign password-reset tokens. Generate with: openssl rand -hex 32
RESET_SECRET=

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=
