generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL bypasses PgBouncer for migrations — required by Supabase + Prisma
  directUrl = env("DIRECT_URL")
}

model Inquiry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  name    String
  email   String
  company String?
  website String?

  service     String
  description String  @db.Text
  budgetRange String? @map("budget_range")
  timeline    String?

  status     String    @default("INQUIRY")
  approvedAt DateTime? @map("approved_at") @db.Timestamptz()

  source      String?
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")
  referrer    String?
  metadata    Json?

  user          User?
  companyRecord Company?
  project       Project?

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([email])
  @@map("inquiries")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  inquiryId String? @unique @map("inquiry_id") @db.Uuid
  companyId String? @map("company_id") @db.Uuid

  name         String
  email        String  @unique
  passwordHash String? @map("password_hash")
  role         String  @default("CLIENT")
  status       String  @default("INVITED")
  admin        Boolean @default(false)

  templogincode          String?   @map("templogincode")
  tempLoginCodeExpiresAt DateTime? @map("temp_login_code_expires_at") @db.Timestamptz()

  invitedAt   DateTime? @map("invited_at") @db.Timestamptz()
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz()

  inquiry  Inquiry?  @relation(fields: [inquiryId], references: [id])
  company  Company?  @relation(fields: [companyId], references: [id])
  projects Project[] @relation("ProjectPrimaryUser")

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@map("users")
}

model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  inquiryId String? @unique @map("inquiry_id") @db.Uuid

  name    String
  website String?
  status  String  @default("ACTIVE")

  inquiry  Inquiry?  @relation(fields: [inquiryId], references: [id])
  users    User[]
  projects Project[]

  @@index([name])
  @@index([status])
  @@map("companies")
}

model Service {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  name  String
  order Int    @default(0)

  subCategories ServiceSubCategory[]

  @@unique([name])
  @@index([order])
  @@map("services")
}

model ServiceSubCategory {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId String @map("service_id") @db.Uuid

  name  String
  order Int    @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, name])
  @@index([order])
  @@map("service_sub_categories")
}

model Invoice {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  invoiceNumber String  @map("invoice_number")
  issueDate     String  @map("issue_date")
  dueDate       String  @map("due_date")
  clientName    String  @map("client_name")
  clientEmail   String  @map("client_email")
  clientCompany String? @map("client_company")
  projectName   String  @map("project_name")
  taxRate       Float   @default(0) @map("tax_rate")
  status        String  @default("Unsent")

  lineItems InvoiceLineItem[]

  @@index([createdAt(sort: Desc)])
  @@index([clientEmail])
  @@map("invoices")
}

model InvoiceLineItem {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId String @map("invoice_id") @db.Uuid

  description String
  qty         Float
  rate        Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Project {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  inquiryId     String? @unique @map("inquiry_id") @db.Uuid
  companyId     String  @map("company_id") @db.Uuid
  primaryUserId String? @map("primary_user_id") @db.Uuid

  name        String
  service     String
  subCategory String? @map("sub_category")
  description String  @db.Text
  budgetRange String? @map("budget_range")
  timeline    String?

  status String @default("ONBOARDING")

  startDate     DateTime? @map("start_date") @db.Date
  targetEndDate DateTime? @map("target_end_date") @db.Date
  completedAt   DateTime? @map("completed_at") @db.Timestamptz()

  inquiry     Inquiry? @relation(fields: [inquiryId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])
  primaryUser User?    @relation("ProjectPrimaryUser", fields: [primaryUserId], references: [id])

  @@index([companyId])
  @@index([primaryUserId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("projects")
}
